# 沙箱镜像本地构建/直推的部署变量模板。
# 复制为 sandbox/.deploy.env(已 gitignored,绝不入库)填真实值;build-and-ship.sh 会自动 source。
# 真实主机/IP/SSH key 放在 ~/.ssh/config,不放这里、更不入这个 public fork 仓。

# PLATFORM 必须匹配 prod 主机架构。先 `ssh <你的 prod 别名> uname -m`:
#   x86_64 → linux/amd64(阿里云 r/c/g 等 x86 实例);aarch64 → linux/arm64。
PLATFORM=linux/amd64

# PROD_SSH = 你 ~/.ssh/config 里的 prod 主机别名(建议走 tailnet,快且不耗公网带宽)。
PROD_SSH=prod

# 可选:镜像名:tag(默认 med_agent_repo:<git short sha>,匹配你 ACR 仓库名也可)。
# IMAGE=med_agent_repo:v1
