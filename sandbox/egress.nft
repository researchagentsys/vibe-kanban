# sandbox/egress.nft — host-side egress policy for tenant sandboxes (TEMPLATE).
#
# Goal: default-DENY egress with a small allowlist, and HARD-block the cloud
# metadata endpoint so a compromised agent cannot steal instance credentials.
#
#   Alibaba Cloud metadata service = 100.100.100.200  (NOT 169.254.169.254).
#   Reaching it leaks the instance RAM-role credentials -> full account takeover.
#
# This is a starting point for the Docker-on-VMs (P0) path, applied on the host
# to the per-tenant bridge interface. For Kubernetes use k8s/networkpolicy.yaml
# instead. For hostname-based allowlisting (npm/github/pypi), prefer routing all
# tenant egress through an explicit egress proxy (Squid/Envoy) rather than pinning
# IPs here — registry IPs change.

table inet vk_egress {
    set allowed_v4 {
        type ipv4_addr
        flags interval
        # Pin allowlisted service IP ranges here, OR leave empty and force all
        # 80/443 through an egress proxy address you control.
        # elements = { 1.2.3.0/24 }
    }

    chain forward {
        type filter hook forward priority 0; policy drop;

        # 1) Hard-block cloud metadata + link-local (defense in depth).
        ip daddr 100.100.100.200 drop
        ip daddr 169.254.0.0/16  drop

        # 2) Block lateral movement to private ranges (control plane, other tenants).
        #    NOTE: Alibaba internal services (incl. DNS) live in 100.64.0.0/10;
        #    we drop the metadata IP specifically and allow only the DNS IPs below.
        ip daddr 10.0.0.0/8     drop
        ip daddr 172.16.0.0/12  drop
        ip daddr 192.168.0.0/16 drop

        # 3) Allow established/related return traffic.
        ct state established,related accept

        # 4) Allow DNS to the Alibaba resolver only (adjust to your VPC resolver).
        ip daddr { 100.100.2.136, 100.100.2.138 } udp dport 53 accept
        ip daddr { 100.100.2.136, 100.100.2.138 } tcp dport 53 accept

        # 5) Allow the egress allowlist (or send all 80/443 to your egress proxy).
        ip daddr @allowed_v4 tcp dport { 80, 443 } accept

        # everything else dropped by `policy drop`
    }
}
